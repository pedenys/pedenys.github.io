{"componentChunkName":"component---src-templates-blog-post-js","path":"/list-git-branches/","result":{"data":{"markdownRemark":{"html":"<div class=\"gatsby-highlight\" data-language=\"bash\"><pre class=\"language-bash\"><code class=\"language-bash\"><span class=\"token comment\"># show local and remote branches</span>\n<span class=\"token function\">git</span> branch -a\n<span class=\"token comment\"># show only remote branches</span>\n<span class=\"token function\">git</span> branch -r\n<span class=\"token comment\"># show only local branches</span>\n<span class=\"token function\">git</span> branch -l</code></pre></div>","frontmatter":{"title":"List git branches"}}},"pageContext":{"slug":"/list-git-branches/"}},"staticQueryHashes":[]}